###############################################
# VoiceSwap Backend — Environment Variables   #
###############################################
# ⚠️  Never commit this file to Git. It's already in .gitignore.

# Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (default: gemini-2.5-flash)
# If you hit quota errors, try gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud service account JSON key file
# Used for Google Text-to-Speech API
# Download from Google Cloud Console → IAM → Service Accounts → Create Key → JSON
# Example path: ./credentials/gcp-key.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json

# Google Cloud project ID (for TTS)
GCP_PROJECT_ID=your_gcp_project_id_here

# (Optional) Vercel frontend URL for CORS
FRONTEND_URL=https://your-app.vercel.app

# (Optional) Override temp directory location
# TMP_DIR=./tmp

# (Optional) ADK API key (for Google ADK integration)
# ADK_API_KEY=your_adk_api_key_here

# (Optional) Enable debug logging
# DEBUG=true
