# VoiceSwap Backend — Environment Variables
# ⚠️  Never commit this file to Git. It's already in .gitignore.

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model to use (optional — default: gemini-2.0-flash)
# If you hit free-tier quota errors, switch to: gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Path to your Google Cloud service account JSON key file
# Needed for Google Cloud Text-to-Speech
# Get from: Google Cloud Console → IAM → Service Accounts → Create Key → JSON
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json

# (Optional) The Vercel URL of your frontend, for CORS
FRONTEND_URL=https://your-app.vercel.app

# (Optional) Override temp directory location
# TMP_DIR=./tmp
